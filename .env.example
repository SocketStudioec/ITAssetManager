# Copiar a .env en /var/www/apps-node/ITAssetManager/.env
# NUNCA subir el .env real a git.

NODE_ENV=production

# Puerto donde escucha Express (nginx hace proxy a este puerto)
PORT=5000

# Interfaz de escucha. Detrás de nginx en el mismo servidor usar 127.0.0.1
HOST=127.0.0.1

# Conexión a PostgreSQL (OBLIGATORIA — la app no arranca sin esto)
DATABASE_URL=postgresql://usuario:password@localhost:5432/techassets_pro

# Secreto para firmar JWT (OBLIGATORIO en producción — la app no arranca sin esto)
# Generar uno con: openssl rand -hex 32
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# ----------------------------------------------------------------------------
# API de correo (notificaciones de vencimiento) — Socket Studio / begroupmail
# ----------------------------------------------------------------------------
# El scheduler envía recordatorios un día antes de cada vencimiento. La URL y el
# remitente tienen defaults en server/email.ts; el USUARIO y la CONTRASEÑA son
# secretos y deben ponerse aquí (nunca se versionan en git). Son las mismas
# credenciales de la API begroupmail que usa la app Bflash.
MAIL_API_URL=https://api.begroupmail.com/api/email/send
MAIL_API_USER=CAMBIAR_usuario_api_correo
MAIL_API_PASSWORD=CAMBIAR_password_api_correo
MAIL_FROM=TechAssets Pro <info@begroupmail.com>
