# Copia este archivo a .env y rellena tus API keys.
# .env esta ignorado por git (ver .gitignore) — NUNCA lo subas al repo.

# API key de Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key de OpenAI / ChatGPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Proveedor por defecto: anthropic (Claude) u openai (ChatGPT).
# Tambien se puede cambiar por llamada:
#   ITA_AI_PROVIDER=openai python ita_ai.py review server/routes.ts
ITA_AI_PROVIDER=anthropic

# Opcional: modelo de Anthropic.
#   claude-opus-4-8   -> maxima capacidad (por defecto)
#   claude-sonnet-5   -> mas barato, muy bueno para tareas rutinarias
#   claude-haiku-4-5  -> el mas barato/rapido para tareas simples
ITA_AI_MODEL=claude-opus-4-8

# Opcional: modelo de OpenAI para trabajos pesados.
#   gpt-5.6-sol  -> maxima capacidad (por defecto)
#   gpt-5.4-mini -> mas barato para tareas rutinarias
ITA_AI_OPENAI_MODEL=gpt-5.6-sol

# Opcional: tope de tokens de salida por respuesta de texto.
ITA_AI_MAX_TOKENS=8000

# Opcional: tope de tokens para generacion de codigo (comando gen).
ITA_AI_GEN_MAX_TOKENS=32000
